# Copy to .env (git-ignored) and fill in. Placeholders only — never commit real values.

# ============================================================
# Shared (required by BOTH the Telegram bot and the email flow)
# ============================================================

# Anthropic API key — Claude routes each request and refines the prompt.
# Get one at https://console.anthropic.com (API keys).
ANTHROPIC_API_KEY=sk-ant-...

# Fal.ai API key — runs the image generation/edit models.
# Get one at https://fal.ai/dashboard/keys.
FAL_KEY=...

# Optional. Directory holding the reference-asset library (people + brand images).
# Defaults to ./assets (baked into the image). Override only for a mounted volume.
# REFERENCE_ASSETS_DIR=assets

# ============================================================
# Telegram bot — ACTIVE transport (`npm run dev` / production)
# ============================================================

# Bot token from @BotFather (https://t.me/BotFather, /newbot).
# Format: <numeric-id>:<secret>. Treat as a full credential; /revoke if leaked.
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Comma-separated NUMERIC Telegram user ids allowed to use the bot.
# Must be non-empty (startup fails otherwise). To find an id: message the bot
# before being allow-listed — it replies with your id — or send /whoami after.
TELEGRAM_ALLOWLIST=111111111,222222222

# ============================================================
# Email flow — DORMANT (`npm run dev:email` only; ignored by the Telegram bot)
# ============================================================

# The Gmail mailbox the app signs in as (reads requests, sends replies).
GMAIL_USER=images@example.com

# OAuth 2.0 "Desktop app" client id from Google Cloud Console
# (APIs & Services -> Credentials). Ends in .apps.googleusercontent.com.
GOOGLE_OAUTH_CLIENT_ID=...apps.googleusercontent.com

# Secret of that same OAuth client.
GOOGLE_OAUTH_CLIENT_SECRET=...

# Refresh token for GMAIL_USER. Generate with: npm run auth (opens a consent
# URL; sign in AS the mailbox account). Starts with 1//.
GOOGLE_OAUTH_REFRESH_TOKEN=1//...

# Comma-separated sender email addresses allowed to use the email flow
# (case-insensitive From-address match; no SPF/DKIM verification).
ALLOWLIST=teammate1@example.com,teammate2@example.com

# How often to poll the inbox, in seconds (default 15).
POLL_INTERVAL_SECONDS=15
