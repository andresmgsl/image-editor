    "@fal-ai/client": "^1.2.0",
    "dotenv": "^16.4.0",
    "googleapis": "^173.0.0",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.9.0",
    "sharp": "^0.33.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.4",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^6.4.15",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
