{
  "name": "email-image-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "dev": "tsx src/telegram-index.ts",
    "dev:email": "tsx src/email-index.ts",
    "auth": "node scripts/get-refresh-token.mjs",
    "build": "tsc -p tsconfig.build.json",
